# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env 文件：提交 .env(仅含非密钥 DATABASE_URL) 与 .env.example；忽略含密钥的 .env.local
.env.local
.env*.local

# 本地 SQLite 数据库（用 `npx prisma migrate dev` + `npm run seed` 重建）
/dev.db
/dev.db-journal
/dev.db-shm
/dev.db-wal

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Prisma 生成的客户端（postinstall 时由 `prisma generate` 重新生成）
/lib/generated/prisma

# Claude Code 本地个人设置（权限等，因人而异，不提交）
.claude/settings.local.json
